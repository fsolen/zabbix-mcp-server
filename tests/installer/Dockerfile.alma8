# AlmaLinux 8 — system Python is 3.6, python3.9 available
# Expected: installer rejects — no Python >=3.10
FROM almalinux:8

RUN dnf install -y python39 && dnf clean all

COPY . /opt/src
WORKDIR /opt/src

RUN chmod +x deploy/install.sh && \
    deploy/install.sh --dry-run 2>&1 | tee /tmp/output.log; \
    grep -q "No suitable Python" /tmp/output.log && echo "PASS: correctly rejected python3.9" || \
    (echo "FAIL: should have rejected python3.9" && exit 1)
