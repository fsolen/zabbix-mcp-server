# Docker environment variables for zabbix-mcp-server.
# Copy this file to .env and adjust values.
#
# MCP_HOST - host interface to bind on the Docker host.
#   127.0.0.1  listen on localhost only (default, recommended)
#   0.0.0.0    listen on all interfaces
MCP_HOST=127.0.0.1

# MCP_PORT - port used inside the container and exposed on the Docker host.
# This overrides the 'port' setting in config.toml when running via Docker.
MCP_PORT=8080

# MCP_AUTH_TOKEN - bearer token for MCP server authentication (optional).
# When set, MCP clients must send: Authorization: Bearer <token>
#
# IMPORTANT: This alone is not enough! You must ALSO uncomment the following
# line in config.toml:   auth_token = "${MCP_AUTH_TOKEN}"
# and then set the actual token value here below.
#
# Alternatively, you can set auth_token directly in config.toml — that is
# the preferred way if you don't need environment variable substitution.
#
# MCP_AUTH_TOKEN=your-secret-token-here
